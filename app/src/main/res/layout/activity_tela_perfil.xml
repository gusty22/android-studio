<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@drawable/bg_degrade"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Seja Bem-vindo!"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginTop="60dp"
        android:layout_marginBottom="32dp" />

    <ImageView
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:background="@drawable/shape_circulo_perfil"
        android:src="@drawable/ic_person"
        android:scaleType="centerInside"
        android:padding="24dp"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/txtNomePerfil"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nome da Pessoa"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/txtEmailPerfil"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="usuario@email.com"
        android:textSize="16sp"
        android:textColor="#666666" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>

    <Button
        android:id="@+id/btnSair"
        style="@style/FormButtonStyle"
        android:layout_width="match_parent"
        android:text="Sair da Conta"
        android:background="@drawable/shape_button_primary"
        android:layout_marginBottom="16dp" />

</LinearLayout>